# Didit KYC provider credentials
# Get these from https://business.didit.me/ after creating a workflow
DIDIT_API_KEY=your_didit_api_key_here
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret_here
DIDIT_WORKFLOW_ID=your_didit_workflow_id_here

# Server
PORT=3001

# CORS origin for demo app
CORS_ORIGIN=http://localhost:3000
MINA_SIGNER_NETWORK=mainnet

# Optional: required only if you want POST /api/mina/issue-credential to work
# Generate with: node -e "const { PrivateKey } = require('o1js'); console.log(PrivateKey.random().toBase58())"
MINA_ISSUER_PRIVATE_KEY=
