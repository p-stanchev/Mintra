{
  "name": "mintra",
  "private": true,
  "scripts": {
    "build:packages": "pnpm --filter @mintra/sdk-types build && pnpm --filter @mintra/provider-didit build && pnpm --filter @mintra/sdk-js build && pnpm --filter @mintra/mina-bridge build",
    "build": "pnpm run build:packages && pnpm --filter @mintra/api build",
    "dev": "pnpm --parallel -r dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:push": "pnpm --filter @mintra/api db:push",
    "db:studio": "pnpm --filter @mintra/api db:studio"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
