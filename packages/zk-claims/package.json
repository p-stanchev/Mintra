{
  "name": "@mintra/zk-claims",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool forks --fileParallelism false",
    "print-vk-hashes": "./node_modules/.bin/tsx scripts/print-vk-hashes.ts",
    "gen-keys": "./node_modules/.bin/tsx scripts/gen-keys.ts"
  },
  "dependencies": {
    "@mintra/credential-v2": "workspace:*",
    "o1js": "^2.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
