{
  "name": "@mintra/zk-contracts",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "compile:local": "pnpm run build && node dist/scripts/compile.js",
    "gen-keys": "pnpm run build && node dist/scripts/gen-keys.js",
    "deploy": "pnpm run deploy:registry",
    "deploy:registry": "pnpm run build && node dist/scripts/deploy-registry.js",
    "update:registry": "pnpm run build && node dist/scripts/update-registry.js",
    "publish:attestation": "pnpm run build && node dist/scripts/publish-attestation.js",
    "revoke:attestation": "pnpm run build && node dist/scripts/revoke-attestation.js",
    "deploy:age-gate": "pnpm run build && node dist/scripts/deploy.js",
    "update:age-gate-policy": "pnpm run build && node dist/scripts/update-policy.js"
  },
  "dependencies": {
    "@mintra/credential-v2": "workspace:*",
    "@mintra/zk-claims": "workspace:*",
    "o1js": "^2.3.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
